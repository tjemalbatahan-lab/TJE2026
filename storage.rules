rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // O app não usa o Firebase Storage (exige plano pago Blaze).
    // O comprovante de pagamento é salvo direto como imagem em base64
    // no próprio documento da inscrição, no Firestore.
    match /{tudo=**} {
      allow read, write: if false;
    }
  }
}
